{
	"version": 6,
	"cmakeMinimumRequired": {
		"major": 3,
		"minor": 25,
		"patch": 0
	},
	"configurePresets": [
		{
			"name": "windows-x64",
			"displayName": "Windows x64 (Ninja Multi-Config)",
			"description": "64-bit multi-config build; exports compile_commands.json for clangd",
			"generator": "Ninja Multi-Config",
			"binaryDir": "${sourceDir}/build",
			"architecture": {
				"value": "x64",
				"strategy": "external"
			},
			"cacheVariables": {
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		}
	],
	"buildPresets": [
		{
			"name": "windows-x64-debug",
			"displayName": "Debug",
			"configurePreset": "windows-x64",
			"configuration": "Debug"
		},
		{
			"name": "windows-x64-release",
			"displayName": "Release",
			"configurePreset": "windows-x64",
			"configuration": "Release"
		}
	]
}
